{
  "extends": "./node_modules/astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@core/*": ["./src/core/*"],
      "@shared/*": ["./src/shared/*"],
      "@features/*": ["./src/features/*"]
    },
    "types": ["astro/client", "node"]
  },
  "include": [".astro/types.d.ts", "astro.config.mjs", "src/**/*"],
  "exclude": ["dist", "node_modules"]
}
