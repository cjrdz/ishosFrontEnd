  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.8",
    "@astrojs/svelte": "^8.0.4",
    "@iconify/svelte": "^5.2.1",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^6.1.3",
    "daisyui": "^5.5.14",
    "echarts": "^5.6.0",
    "rollup": "^4.52.4",
    "svelte": "^5.53.2",
    "svelte-echarts": "^1.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/vercel": "^10.0.4",
    "@types/node": "^25.6.0",
