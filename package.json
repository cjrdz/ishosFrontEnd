{
  "name": "ishosfactory",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "DEPLOY_TARGET=vercel astro dev --host 0.0.0.0 --port 4321",
    "dev:cloudflare": "astro dev",
    "dev:lan": "DEPLOY_TARGET=vercel astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "build:cloudflare": "DEPLOY_TARGET=cloudflare astro build",
    "build:vercel": "DEPLOY_TARGET=vercel astro build",
    "deploy": "pnpm run build:cloudflare && wrangler deploy",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "pnpm audit --audit-level moderate",
    "audit:fix": "pnpm audit --fix",
    "lint": "tsc --noEmit && astro check",
    "lint:types": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.8",
    "@astrojs/svelte": "^8.0.4",
    "@iconify-json/lucide": "^1.2.102",
    "@iconify/svelte": "^5.2.1",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^6.1.3",
    "daisyui": "^5.5.14",
    "echarts": "^5.6.0",
    "motion": "^12.38.0",
    "rollup": "^4.52.4",
    "svelte": "^5.53.5",
    "svelte-echarts": "^1.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/vercel": "^10.0.4",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  },
  "lint-staged": {
    "*.{ts,js,svelte,astro,json}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "h3": ">=1.15.6",
      "picomatch": ">=4.0.4",
      "defu": ">=6.1.5",
      "devalue": ">=5.6.4",
      "svelte": ">=5.53.5",
      "smol-toml": ">=1.6.1",
      "yaml": ">=2.8.3"
    }
  }
}
