---
import Icon from "../../svelte/shared/AppIcon.svelte";
---

<footer class="bg-base-200 text-base-content border-t border-base-300/60">
  <aside
    class="mx-auto flex w-full max-w-4xl flex-col items-center gap-2 px-6 py-10 text-center"
  >
    <p class="text-lg font-semibold tracking-wide">Isho's Factory</p>
    <p class="text-sm text-base-content/80">
      © {new Date().getFullYear()} Todos los derechos reservados.
    </p>

    <p class="mt-1 inline-flex items-center gap-2 text-sm text-base-content/85">
      <Icon
        icon="proicons:code"
        class="h-5 w-5 text-primary"
        aria-hidden="true"
      />
      <span>
        Creado por
        <a
          href="https://jrdz.dev/about/"
          target="_blank"
          rel="noopener noreferrer"
          class="link link-hover link-primary font-medium"
        >
          jrdz.dev
        </a>
      </span>
    </p>
  </aside>
</footer>
