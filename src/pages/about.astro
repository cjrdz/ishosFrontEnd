---
import StoreLayout from "../layouts/StoreLayout.astro";
---

<StoreLayout title="IshosFactory - Nosotros">
  <div
    class="container mx-auto px-4 pt-3 pb-8 md:pt-4 md:pb-12 space-y-10 md:space-y-14"
  >
    {/* ── Hero / Story Section ── */}
    <section class="max-w-4xl mx-auto text-center px-2">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-2 tracking-tight">
        <span
          class="text-transparent bg-clip-text bg-linear-to-r from-primary to-secondary"
        >
          Isho's Factory
        </span>
      </h1>
      <p
        class="text-base-content/50 text-xs font-bold uppercase tracking-widest mb-5"
      >
        Gelatos &amp; Sorbetes Artesanales
      </p>

      <div
        class="relative card bg-base-100/50 backdrop-blur-sm shadow-xl border border-base-200/50 rounded-3xl overflow-hidden transition-all duration-300 hover:shadow-2xl hover:border-primary/20"
      >
        {/* decorative blobs */}
        <div
          class="absolute -top-12 -right-12 w-48 h-48 rounded-full bg-primary/10 blur-3xl pointer-events-none"
        >
        </div>
        <div
          class="absolute -bottom-12 -left-12 w-48 h-48 rounded-full bg-secondary/10 blur-3xl pointer-events-none"
        >
        </div>

        <div
          class="card-body p-6 md:p-10 items-center text-center relative z-10"
        >
          <div
            class="badge badge-primary badge-outline px-4 py-3 font-bold text-xs uppercase tracking-widest mb-4"
          >
            Desde 2021
          </div>

          <p
            class="text-lg md:text-xl text-base-content/80 leading-relaxed max-w-3xl font-medium"
          >
            Isho's Factory ha sido sinónimo de <span
              class="text-primary font-bold">tradición</span
            > y <span class="text-secondary font-bold">calidad</span> en El Salvador.
            Nuestros helados artesanales son preparados con los mejores ingredientes
            y mucho amor. Cada bola de helado cuenta una historia de sabor auténtico
            y dedicación. Visítanos y descubre por qué generaciones de salvadoreños
            nos eligen.
          </p>

          <div class="flex flex-wrap gap-3 justify-center mt-6">
            <div
              class="badge badge-lg badge-primary badge-outline px-5 py-4 font-semibold text-sm md:text-base shadow-sm"
            >
              ✨ Artesanal
            </div>
            <div
              class="badge badge-lg badge-secondary badge-outline px-5 py-4 font-semibold text-sm md:text-base shadow-sm"
            >
              🍃 Ingredientes Naturales
            </div>
            <div
              class="badge badge-lg badge-accent badge-outline px-5 py-4 font-semibold text-sm md:text-base shadow-sm"
            >
              🇸🇻 Hecho en El Salvador
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Values Section ── */}
    <section class="max-w-4xl mx-auto px-2">
      <div class="text-center mb-7">
        <h2 class="text-3xl md:text-4xl font-bold text-base-content">
          Lo que nos define
        </h2>
        <p class="text-base-content/50 mt-2 font-medium">
          Los pilares de nuestra marca
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {/* Calidad */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl text-center"
        >
          <div class="card-body items-center p-7">
            <div
              class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-3 text-primary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-1">Calidad</h3>
            <p class="text-base-content/60 text-sm">
              Solo los mejores ingredientes llegan a nuestras recetas.
            </p>
          </div>
        </div>

        {/* Tradición */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl text-center"
        >
          <div class="card-body items-center p-7">
            <div
              class="w-14 h-14 rounded-full bg-secondary/10 flex items-center justify-center mb-3 text-secondary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-1">Tradición</h3>
            <p class="text-base-content/60 text-sm">
              Más de 4 años llevando sabores auténticos a cada familia.
            </p>
          </div>
        </div>

        {/* Pasión */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl text-center"
        >
          <div class="card-body items-center p-7">
            <div
              class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center mb-3 text-accent"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-1">Pasión</h3>
            <p class="text-base-content/60 text-sm">
              Cada helado es hecho con dedicación y amor por lo que hacemos.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Contact Section ── */}
    <section class="max-w-5xl mx-auto px-2">
      <div class="text-center mb-7">
        <h2
          class="text-3xl md:text-4xl font-bold bg-clip-text text-transparent bg-linear-to-r from-base-content to-base-content/60 inline-block"
        >
          📍 Contáctanos
        </h2>
        <p class="text-base-content/60 mt-3 font-medium text-lg">
          Estamos para servirte. Encuéntranos o comunícate con nosotros.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {/* Location Card */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl"
        >
          <div class="card-body items-center text-center p-8">
            <div
              class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-4 text-primary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">Visítanos</h3>
            <p class="text-base-content/70">Ahuachapán<br />El Salvador</p>
          </div>
        </div>

        {/* Call/WhatsApp Card */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl"
        >
          <div class="card-body items-center text-center p-8">
            <div
              class="w-14 h-14 rounded-full bg-success/10 flex items-center justify-center mb-4 text-success"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-4">Llámanos</h3>
            <div
              class="flex flex-col sm:flex-row gap-3 w-full justify-center mt-auto"
            >
              <a
                class="btn btn-primary btn-sm sm:btn-md sm:w-auto w-full rounded-full shadow-sm hover:shadow-md"
                href="tel:+50376454347"
              >
                Llamar
              </a>
              <a
                class="btn btn-success btn-sm sm:btn-md text-white sm:w-auto w-full rounded-full shadow-sm hover:shadow-md"
                href="https://wa.me/50376454347"
                target="_blank"
                rel="noopener noreferrer"
              >
                WhatsApp
              </a>
            </div>
          </div>
        </div>

        {/* Schedule Card */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl"
        >
          <div class="card-body items-center text-center p-8">
            <div
              class="w-14 h-14 rounded-full bg-secondary/10 flex items-center justify-center mb-4 text-secondary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Horario</h3>
            <div class="w-full space-y-2 mt-auto">
              <div
                class="flex justify-between items-center text-sm bg-base-200/50 py-2 px-4 rounded-xl"
              >
                <span class="font-semibold text-base-content/80">Lun - Vie</span
                >
                <span class="text-base-content/70">10:30 AM - 6:30 PM</span>
              </div>
              <div
                class="flex justify-between items-center text-sm bg-base-200/50 py-2 px-4 rounded-xl"
              >
                <span class="font-semibold text-base-content/80">Domingo</span>
                <span class="text-base-content/70">10:30 AM - 6:30 PM</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Social Media Row */}
      <div class="mt-8">
        <h3
          class="text-center text-sm font-bold mb-5 text-base-content/60 uppercase tracking-widest"
        >
          Síguenos en Redes Sociales
        </h3>
        <div class="flex flex-wrap justify-center gap-5">
          {/* Instagram */}
          <a
            href="https://www.instagram.com/ishos_factory/?hl=en"
            target="_blank"
            rel="noopener noreferrer"
            class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl w-36 cursor-pointer"
            aria-label="Instagram"
          >
            <div class="card-body items-center text-center p-5">
              <svg
                class="w-9 h-9 mb-1"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <defs>
                  <linearGradient
                    id="ig-grad"
                    x1="0%"
                    y1="100%"
                    x2="100%"
                    y2="0%"
                  >
                    <stop offset="0%" style="stop-color:#f09433"></stop>
                    <stop offset="25%" style="stop-color:#e6683c"></stop>
                    <stop offset="50%" style="stop-color:#dc2743"></stop>
                    <stop offset="75%" style="stop-color:#cc2366"></stop>
                    <stop offset="100%" style="stop-color:#bc1888"></stop>
                  </linearGradient>
                </defs>
                <rect
                  x="2"
                  y="2"
                  width="20"
                  height="20"
                  rx="5"
                  ry="5"
                  stroke="url(#ig-grad)"
                  stroke-width="2"
                  fill="none"></rect>
                <circle
                  cx="12"
                  cy="12"
                  r="4"
                  stroke="url(#ig-grad)"
                  stroke-width="2"
                  fill="none"></circle>
                <circle cx="17.5" cy="6.5" r="1" fill="url(#ig-grad)"></circle>
              </svg>
              <span class="text-sm font-semibold" style="color:#E4405F;"
                >Instagram</span
              >
            </div>
          </a>

          {/* Facebook */}
          <a
            href="https://www.facebook.com/ishosfactory/"
            target="_blank"
            rel="noopener noreferrer"
            class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl w-36 cursor-pointer"
            aria-label="Facebook"
          >
            <div class="card-body items-center text-center p-5">
              <svg
                class="w-9 h-9 mb-1"
                viewBox="0 0 24 24"
                fill="#1877F2"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"
                ></path>
              </svg>
              <span class="text-sm font-semibold" style="color:#1877F2;"
                >Facebook</span
              >
            </div>
          </a>

          {/* TikTok */}
          <a
            href="https://www.tiktok.com/@ishosfactory"
            target="_blank"
            rel="noopener noreferrer"
            class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl w-36 cursor-pointer"
            aria-label="TikTok"
          >
            <div class="card-body items-center text-center p-5">
              <svg
                class="w-9 h-9 mb-1"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.55V6.79a4.85 4.85 0 01-1.07-.1z"
                  fill="currentColor"></path>
              </svg>
              <span class="text-sm font-semibold text-base-content">TikTok</span
              >
            </div>
          </a>
        </div>
      </div>
    </section>

    {/* ── Location Maps Section ── */}
    <section class="max-w-5xl mx-auto px-2 pb-8">
      <div class="text-center mb-7">
        <h2
          class="text-3xl md:text-4xl font-bold bg-clip-text text-transparent bg-linear-to-r from-base-content to-base-content/60 inline-block"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="inline-block w-8 h-8 mr-2 align-middle"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 20.25l-4.5-1.5V4.5l4.5 1.5m0 14.25l6-2m-6 2V6l6-2m0 16.25l4.5 1.5V5.25l-4.5-1.5m0 16.5V4.5"
            ></path></svg
          > Nuestras Sucursales
        </h2>
        <p class="text-base-content/60 mt-3 font-medium text-lg">
          Encuéntranos en Ahuachapán, El Salvador.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {/* Sucursal 1 */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl transition-all duration-300 rounded-2xl overflow-hidden"
        >
          <div class="card-body p-0">
            <div class="p-5 pb-3">
              <h3 class="text-lg font-bold flex items-center gap-2">
                <span class="text-primary">📍</span> Isho's Sucursal 1
              </h3>
              <p class="text-base-content/60 text-sm mt-1">
                Ahuachapán, El Salvador
              </p>
            </div>
            <div class="w-full h-56 md:h-64">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6847.623198808501!2d-89.8518696249066!3d13.92355228648646!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8f6297001f790639%3A0xa292396c664dfae0!2sIsho%E2%80%99s%20Sucursal%201!5e1!3m2!1ses!2ssv!4v1777132497595!5m2!1ses!2ssv"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Mapa de Isho's Sucursal 1"></iframe>
            </div>
            <div class="p-4 pt-3">
              <a
                href="https://maps.google.com/?q=Isho%27s+Sucursal+1,+Ahuachap%C3%A1n,+El+Salvador"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary btn-sm w-full rounded-xl"
              >
                Obtener Direcciones
              </a>
            </div>
          </div>
        </div>

        {/* Sucursal 2 */}
        <div
          class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl transition-all duration-300 rounded-2xl overflow-hidden"
        >
          <div class="card-body p-0">
            <div class="p-5 pb-3">
              <h3 class="text-lg font-bold flex items-center gap-2">
                <span class="text-primary">📍</span> Isho's Sucursal 2
              </h3>
              <p class="text-base-content/60 text-sm mt-1">
                Ahuachapán, El Salvador
              </p>
            </div>
            <div class="w-full h-56 md:h-64">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6847.705736039818!2d-89.8483311!3d13.920766299999997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8f6297004861f67d%3A0xfed9bfb450de212f!2sIsho%E2%80%99s%20sucursal%202!5e1!3m2!1ses!2ssv!4v1777132555390!5m2!1ses!2ssv"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Mapa de Isho's Sucursal 2"></iframe>
            </div>
            <div class="p-4 pt-3">
              <a
                href="https://maps.app.goo.gl/bSYLeqagKbSW3wUh8"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary btn-sm w-full rounded-xl"
              >
                Obtener Direcciones
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</StoreLayout>
