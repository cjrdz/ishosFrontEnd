---
import "../styles/global.css";
import "../styles/variables.css";
import { ClientRouter } from "astro:transitions";
import StoreNavbar from "@shared/components/StoreNavbar.astro";
import StoreFooter from "@shared/components/StoreFooter.astro";
import Icon from "@shared/components/AppIcon.svelte";

interface Props {
  title: string;
}

const { title } = Astro.props as Props;
---

<!doctype html>
<html
  lang="es"
  data-theme="night"
  class="bg-base-200"
  transition:name="store-root"
  transition:animate="none"
>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Isho's Gelatos & Sorbetes - Tienda en línea"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        const themeWindow = window;
        if (themeWindow.__ishosThemeSyncBound) return;
        themeWindow.__ishosThemeSyncBound = true;

        const resolveTheme = () => {
          const savedTheme =
            localStorage.getItem("ishos_theme_store") ??
            localStorage.getItem("theme");
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;

          return savedTheme === "fantasy" || savedTheme === "night"
            ? savedTheme
            : prefersDark
              ? "night"
              : "fantasy";
        };

        const applyTheme = (targetDocument) => {
          if (!targetDocument?.documentElement) return;
          targetDocument.documentElement.setAttribute(
            "data-theme",
            resolveTheme(),
          );
        };

        // Initial page load
        applyTheme(document);

        // Apply theme to incoming document before it swaps in to avoid flash.
        document.addEventListener("astro:before-swap", (event) => {
          applyTheme(event.newDocument);
        });

        // Re-assert after swap/page load as safety for script/theme toggles.
        document.addEventListener("astro:after-swap", () => {
          applyTheme(document);
        });

        document.addEventListener("astro:page-load", () => {
          applyTheme(document);
        });
      })();
    </script>
  </head>
  <body class="bg-base-200 text-base-content min-h-screen flex flex-col">
    <StoreNavbar transition:animate="none" />
    <main class="flex-1 store-main">
      <slot />
    </main>
    <StoreFooter transition:animate="none" />

    <div
      id="store-cart-toast"
      class="toast toast-end toast-top z-70 hidden"
      aria-live="polite"
    >
      <div
        class="alert store-cart-toast-alert bg-base-100 border border-base-300 shadow-xl rounded-2xl"
      >
        <Icon icon="lucide:shopping-bag" class="h-5 w-5 text-primary" />
        <span id="store-cart-toast-text" class="font-medium text-sm"></span>
      </div>
    </div>

    <script is:inline>
      (() => {
        const toastEl = document.getElementById("store-cart-toast");
        const textEl = document.getElementById("store-cart-toast-text");
        if (!toastEl || !textEl) return;

        let hideTimeout;

        const onCartAdded = (event) => {
          const customEvent = event;
          const detail = customEvent?.detail || {};
          const name =
            typeof detail.name === "string" ? detail.name : "Producto";
          const quantity = Number(detail.quantity || 1);
          const qtyLabel = quantity > 1 ? `${quantity}x ` : "";

          textEl.textContent = `${qtyLabel}${name} agregado al carrito`;

          toastEl.classList.remove("hidden");
          toastEl.classList.remove("store-cart-toast-visible");
          void toastEl.offsetWidth;
          toastEl.classList.add("store-cart-toast-visible");

          clearTimeout(hideTimeout);
          hideTimeout = setTimeout(() => {
            toastEl.classList.remove("store-cart-toast-visible");
            setTimeout(() => {
              toastEl.classList.add("hidden");
            }, 220);
          }, 2100);
        };

        document.addEventListener("astro:page-load", () => {
          window.removeEventListener("storefront-cart-added", onCartAdded);
          window.addEventListener("storefront-cart-added", onCartAdded);
        });

        window.removeEventListener("storefront-cart-added", onCartAdded);
        window.addEventListener("storefront-cart-added", onCartAdded);
      })();
    </script>

    <script>
      import { animate } from "motion";

      const motionWindow = window as typeof window & {
        __ishosStoreMotionBound?: boolean;
        __ishosStoreEnterAnim?: ReturnType<typeof animate> | null;
      };

      if (!motionWindow.__ishosStoreMotionBound) {
        motionWindow.__ishosStoreMotionBound = true;
        motionWindow.__ishosStoreEnterAnim = null;

        // Enter-only motion avoids overlay artifacts between different page themes.
        document.addEventListener("astro:page-load", () => {
          const main = document.querySelector<HTMLElement>("main.store-main");
          if (!main) return;

          const prefersReducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          if (motionWindow.__ishosStoreEnterAnim) {
            motionWindow.__ishosStoreEnterAnim.cancel();
            motionWindow.__ishosStoreEnterAnim = null;
          }

          if (prefersReducedMotion) {
            main.style.opacity = "1";
            main.style.transform = "none";
            return;
          }

          main.style.opacity = "0";
          main.style.transform = "scale(1.01)";

          motionWindow.__ishosStoreEnterAnim = animate(
            main,
            { opacity: [0, 1], scale: [1.01, 1] },
            { duration: 0.28, ease: [0, 0, 0.2, 1] },
          );
        });
      }
    </script>

    <style is:global>
      #store-cart-toast .store-cart-toast-alert {
        opacity: 0;
        transform: translateY(-10px) scale(0.98);
        transition:
          opacity 220ms ease,
          transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
      }

      #store-cart-toast.store-cart-toast-visible .store-cart-toast-alert {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      @media (prefers-reduced-motion: reduce) {
        #store-cart-toast .store-cart-toast-alert {
          transition: none;
          transform: none;
        }
      }
    </style>
  </body>
</html>
