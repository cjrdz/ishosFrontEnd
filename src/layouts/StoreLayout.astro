---
import "../styles/global.css";
import "../styles/variables.css";
import StoreNavbar from "../components/astro/StoreNavbar.astro";
import StoreFooter from "../components/astro/StoreFooter.astro";

interface Props {
  title: string;
}

const { title } = Astro.props as Props;
---

<!doctype html>
<html lang="es" data-theme="night" class="bg-base-200">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Isho's Gelatos & Sorbetes - Tienda en línea" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-base-200 text-base-content min-h-screen flex flex-col">
    <StoreNavbar />
    <main class="flex-1">
      <slot />
    </main>
    <StoreFooter />
  </body>
</html>
